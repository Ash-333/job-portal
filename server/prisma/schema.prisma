// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  EMPLOYER
  ADMIN
}

enum ExperienceLevel {
  STUDENT
  FRESHER
  INTERNSHIP_ONLY
  ZERO_TO_ONE_YEAR
  ONE_TO_THREE_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_PLUS_YEARS
  THREE_PLUS_YEARS  // Keep for backward compatibility
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkLocationType {
  ONSITE
  REMOTE
  HYBRID
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMITTED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  ACCEPTED
  REJECTED
  HIRED
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String
  phone           String?
  experienceLevel ExperienceLevel?
  role            UserRole        @default(USER)

  // Email verification
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationExpires DateTime?

  // Password reset
  passwordResetToken      String?   @unique
  passwordResetExpires    DateTime?

  // Profile information
  firstName       String?
  lastName        String?
  profilePicture  String?         // Supabase Storage URL
  resume          String?         // Supabase Storage URL
  bio             String?
  skills          String[]        // Array of skills
  experience      String?         // Work experience
  education       String?         // Education background
  location        String?
  website         String?
  linkedin        String?
  github          String?

  // Employer fields
  companyName        String?
  companySlug        String?   @unique
  companyDescription String?
  companyLogo        String?
  companyWebsite     String?
  companySize        String?
  industry           String?

  // Account status
  isActive           Boolean   @default(true)

  // Profile completion
  profileCompleted Boolean        @default(false)

  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  applications    Application[]
  postedJobs      Job[]              @relation("JobToUser")
  subscription    EmployerSubscription?
  sponsorship     SponsoredCompany?
  cvUnlocksEarned CVUnlock[]         @relation("CVUnlockCandidate")
  cvUnlocksPurchased CVUnlock[]      @relation("CVUnlockEmployer")

  @@index([createdAt])
  @@index([role, companyName])

  @@map("users")
}

enum JobSource {
  ADMIN
  EMPLOYER
}

model Job {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  description     String
  requirements    String[]    // Array of requirements
  responsibilities String[]   // Array of responsibilities

  // Job details
  category        String
  location        String
  jobType         JobType     @default(FULL_TIME)
  workLocationType WorkLocationType @default(ONSITE)
  experienceLevel ExperienceLevel
  salaryMin       Int?
  salaryMax       Int?
  salaryNegotiable Boolean?    @default(false)
  currency        String      @default("NPR")

  // Company info
  companyName     String
  companySlug     String?     // Denormalized from employer User, null for admin-created jobs
  companyLogo     String?     // Supabase Storage URL
  companyWebsite  String?

  // SEO and metadata
  metaTitle       String?
  metaDescription String?

  // Source — ADMIN or EMPLOYER
  source          JobSource   @default(ADMIN)

  // Employer relation (null for admin-created jobs)
  postedById      String?
  postedBy        User?       @relation("JobToUser", fields: [postedById], references: [id])

  // Status
  status          JobStatus   @default(PENDING)
  rejectionReason String?
  viewCount       Int         @default(0)
  isActive        Boolean     @default(true)
  isFeatured      Boolean     @default(false)
  isApproved      Boolean     @default(false)
  featuredAt      DateTime?
  applicationDeadline DateTime?

  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  applications    Application[]

  @@index([status, isFeatured, createdAt])
  @@index([postedById, createdAt])
  @@index([applicationDeadline])

  @@map("jobs")
}

model Application {
  id          String            @id @default(cuid())
  message     String?           // Cover letter/message
  status      ApplicationStatus @default(PENDING)

  // Timestamps
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  statusHistory ApplicationStatusHistory[]

  // Unique constraint - user can only apply once per job
  @@unique([userId, jobId])
  @@index([jobId])
  @@index([status])

  @@map("applications")
}

model ApplicationStatusHistory {
  id          String            @id @default(cuid())
  oldStatus   ApplicationStatus
  newStatus   ApplicationStatus
  changedBy   String?           // userId of who made the change (null = system)
  changedAt   DateTime          @default(now())

  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_status_history")
}

model Blog {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String   // Rich text content
  excerpt         String?  // Short description
  featuredImage   String?  // Supabase Storage URL

  // SEO fields
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  // JSON-LD structured data
  structuredData  Json?

  // Status
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished, publishedAt])

  @@map("blogs")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  // userId who performed the action (null for system)
  action    String   // e.g. "JOB_APPROVED", "JOB_REJECTED", "JOB_DELETED", "USER_DELETED", "BLOG_CREATED", etc.
  entity    String   // e.g. "Job", "User", "Blog", "Application"
  entityId  String?  // ID of the affected entity
  metadata  Json?    // Additional context (diff, reason, etc.)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum SubscriptionPlanDuration {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  TRIALING
  ACTIVE
  EXPIRED
  CANCELLED
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  price           Int      @default(0)    // in cents/paisa
  duration        SubscriptionPlanDuration @default(MONTHLY)
  features        Json     @default("[]") // Array of feature keys
  jobLimit        Int?                     // null = unlimited
  featuredJobLimit Int?                    // null = unlimited
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subscriptions   EmployerSubscription[]

  @@map("subscription_plans")
}

model EmployerSubscription {
  id                String             @id @default(cuid())
  employerId        String             @unique
  employer          User               @relation(fields: [employerId], references: [id], onDelete: Cascade)
  planId            String
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  status            SubscriptionStatus @default(PENDING)
  currentPeriodStart DateTime          @default(now())
  currentPeriodEnd  DateTime
  trialEndsAt       DateTime?
  autoRenew         Boolean            @default(true)
  metadata          Json?              // Admin notes
  cancelledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, currentPeriodEnd])
  @@map("employer_subscriptions")
}

model SponsoredCompany {
  id          String   @id @default(cuid())
  employerId  String   @unique
  employer    User     @relation(fields: [employerId], references: [id], onDelete: Cascade)
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isActive, sortOrder])
  @@map("sponsored_companies")
}

model CVUnlock {
  id          String   @id @default(cuid())
  employerId  String
  employer    User     @relation("CVUnlockEmployer", fields: [employerId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User     @relation("CVUnlockCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  unlockedAt  DateTime @default(now())
  expiresAt   DateTime?

  @@unique([employerId, candidateId])
  @@index([employerId])
  @@map("cv_unlocks")
}
